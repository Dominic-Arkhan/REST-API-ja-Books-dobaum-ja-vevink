generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Author {
  id         String  @id @default(uuid())
  firstName  String
  lastName   String
  birthYear  Int
  nationality String
  biography  String?
  createdAt  DateTime @default(now())

  books Book[]
}

model Publisher {
  id          String  @id @default(uuid())
  name        String  @unique
  country     String
  foundedYear Int
  website     String?
  createdAt   DateTime @default(now())

  books Book[]
}

model Genre {
  id        String      @id @default(uuid())
  name      String      @unique
  bookGenres BookGenre[]
}

model Book {
  id           String   @id @default(uuid())
  title        String
  isbn         String   @unique
  publishedYear Int
  pageCount    Int
  language     String
  description  String
  coverImage   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  authorId    String
  publisherId String

  author      Author   @relation(fields: [authorId], references: [id])
  publisher   Publisher @relation(fields: [publisherId], references: [id])

  reviews     Review[]
  bookGenres  BookGenre[]
}

model BookGenre {
  bookId  String
  genreId String

  book   Book  @relation(fields: [bookId], references: [id])
  genre  Genre @relation(fields: [genreId], references: [id])

  @@id([bookId, genreId])
}

model Review {
  id        String   @id @default(uuid())
  bookId    String
  userName  String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id])
}
